# Local development notes — not tracked, but keep the folder + README discoverable
notes/*
!notes/README.md

# Work folder — local experiments, analysis outputs, downloaded .tfl files; not tracked
work/*
!work/README.md
notes/*

# OS / Editor
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# Python (Skill 内 scripts/ で Python を使う場合)
__pycache__/
*.pyc
.venv/
venv/

